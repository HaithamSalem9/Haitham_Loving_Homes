  <script>
        function changeFontSize(scale) {
            let body = document.querySelector("body");
            let currentSize = parseFloat(window.getComputedStyle(body).fontSize);
            body.style.fontSize = (currentSize * scale) + "px";
        }
    </script>

<button class="btn btn-warning bigger_txt" onclick="toggleBackground()" data-lang-en="Night Mode">الوضع الليلي</button>

<script>
function toggleBackground() {
    document.body.style.backgroundColor = 
        document.body.style.backgroundColor === 'black' ? 'white' : 'black';
    document.body.style.color = 
        document.body.style.color === 'white' ? 'black' : 'white';
}

let isEnglish = false;

function toggleLanguage() {
    const elements = document.querySelectorAll('[data-lang-en]');
    elements.forEach(el => {
        const currentText = el.textContent.trim();
        const englishText = el.getAttribute('data-lang-en');
        if (isEnglish) {
            // Switch back to Arabic
            el.textContent = el.getAttribute('data-lang-ar') || currentText;
            document.documentElement.lang = 'ar';
        } else {
            // Switch to English
            el.setAttribute('data-lang-ar', currentText);
            el.textContent = englishText;
            document.documentElement.lang = 'en';
        }
    });
    isEnglish = !isEnglish;
}
</script>

